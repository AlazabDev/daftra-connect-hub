# Alazab Azure AI Operations Console
# Frontend environment variables (public — no secrets here).
# Real Azure credentials are stored ONLY by the backend in Azure Key Vault.

# Base URL of the Azure backend (Functions / Container App / API)
VITE_API_BASE_URL=https://azab-rag-func.azurewebsites.net

# Default brand displayed in headers and selectors
VITE_DEFAULT_BRAND=alazab

# Default UI language (ar | en)
VITE_DEFAULT_LANG=ar
